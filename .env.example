# Environment Variables for Kite Algo Trading
# Copy this file to .env and fill in your values

# ===== REQUIRED - Get from https://kite.zerodha.com/settings/apps =====
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret

# ===== REQUIRED - Access Token =====
# Generate via: python refresh_token.py
KITE_ACCESS_TOKEN=your_access_token_here

# ===== REQUIRED - For Auto Token Refresh =====
KITE_USER_ID=your_kite_user_id
KITE_PASSWORD=your_kite_password
KITE_TOTP_SECRET=your_totp_secret_from_kite

# ===== Optional Settings =====
# Token refresh interval in seconds (default: 3600 = 1 hour)
TOKEN_REFRESH_INTERVAL=3600

# Enable/disable WebSocket (default: true)
ENABLE_WEBSOCKET=true
